// back-end/prisma/schema.prisma

// 1. CONFIGURAÇÃO DA FONTE DE DADOS (DataSource)
datasource db {
  provider = "mongodb" // <-- DEVE SER 'mongodb'
  url      = env("DATABASE_URL")
}

// 2. GERADOR DO CLIENTE PRISMA (Generator)
generator client {
  provider = "prisma-client-js"
}

// 3. MODELOS (Models) - Adiciona o que definimos antes
model Aluno {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  email    String @unique
  senha    String
  nome     String
  notas    Nota[] 
}

model Nota {
  id           String @id @default(auto()) @map("_id") @db.ObjectId
  disciplina   String
  mediaFinal   Float
  alunoId      String @db.ObjectId
  aluno        Aluno  @relation(fields: [alunoId], references: [id])
}